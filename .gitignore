# Local .terraform directories
**/.terraform/*

# Terraform state files (contain resource data, including secrets, in plaintext)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files likely to contain secrets — never commit these
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# Override files (local-only resource overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc
